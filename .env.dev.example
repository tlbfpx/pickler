# =============================================================================
# Hey Pickler — 本机开发环境变量模板（dev profile）
# =============================================================================
# 用途：本机开发 / 本机部署。所有值已填合理默认，开箱即用。
# 用法：
#   cp .env.dev.example .env.dev                # 按需修改
#   set -a; source .env.dev; set +a             # 注入当前 shell
#   bash scripts/dev-up.sh                      # 起依赖 + 打印启动命令
#
# ⚠️ 生产部署请用 .env.example（生产模板，占位符需替换 + prod profile + PROD_GUARD）。
#    本文件仅本机用，请勿用于任何对外可访问的环境。
# =============================================================================

# === 初始 admin（关键！）===
# AdminBootstrapper 在空库首启时必读 INITIAL_ADMIN_PASSWORD，不设会 exit(1)。
# dev 默认密码仅本机用；生产务必改强密码（>=12 字符）。
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=DevAdmin123!

# === DB / Redis（对齐 docker-compose.yml 默认）===
DB_USERNAME=root
DB_PASSWORD=root
REDIS_HOST=localhost
REDIS_PORT=6379

# === 以下 dev profile 已有 fallback，本机无需设置 ===
# JWT_SECRET / AES_KEY / WX_APPID / WX_SECRET / WX_DEV_MODE / CORS_*
# 详见 hey-pickler-server/src/main/resources/application-dev.yml
