# =============================================================================
# Hey Pickler — Production Environment Variables Template
# =============================================================================
# Copy to .env (gitignored) and fill in real values for deployment:
#   cp .env.example .env
#
# Generation commands below. See docs/CREDENTIALS.md for full guidance
# including key rotation and emergency response procedures.
# =============================================================================

# === Database (MySQL 8) ===
DB_URL=jdbc:mysql://your-mysql-host:3306/hey_pickler?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai
DB_USERNAME=hey_pickler_app
# openssl rand -base64 24
DB_PASSWORD=

# === Redis ===
REDIS_HOST=your-redis-host
REDIS_PORT=6379
# openssl rand -base64 24
REDIS_PASSWORD=

# === Crypto keys (CRITICAL — losing these means losing access to encrypted data) ===
# Generate via: openssl rand -base64 48
# Must be >= 32 characters. Recommend exactly 48 base64 chars (no '=' padding).
JWT_SECRET=

# Generate via: openssl rand -base64 32  (then trim trailing '=' padding if any)
# MUST be exactly 16, 24, or 32 bytes when decoded as UTF-8. AesUtil @PostConstruct
# validates length at startup and fails fast on invalid lengths.
# Easiest: use a 32-char ASCII string with no special chars.
AES_KEY=

# === Initial admin (first deployment only) ===
# AdminBootstrapper uses these on first startup when admin_user table is empty.
# After the first admin is created, these can be unset — bootstrap is idempotent.
# Generate a one-time password; force password change on first login.
# openssl rand -base64 18  (>= 12 chars recommended)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=

# === WeChat Mini-Program ===
# Obtain from WeChat MP console (https://mp.weixin.qq.com)
WX_APPID=your-real-appid
WX_SECRET=your-real-secret

# === CORS (comma-separated origins) ===
# Admin panel (Vue dev server / production CDN). Must match the origin users see in browser.
CORS_ADMIN_ORIGINS=https://admin.your-domain.com
# Mini-program requests don't have a browser origin — usually empty.
CORS_APP_ORIGINS=

# === Profile & Safety Guard ===
# Always 'prod' for production deployments.
SPRING_PROFILES_ACTIVE=prod
# Set to 'true' to enable defense-in-depth check: refuses to start if active
# profile is 'dev' (catches misconfigured prod environments). Strongly recommended.
PROD_GUARD=true

# === JWT expirations (optional, defaults shown) ===
# App (WeChat user) token: 7 days in milliseconds
JWT_APP_EXPIRATION=604800000
# Admin token: 24 hours in milliseconds
JWT_ADMIN_EXPIRATION=86400000

# === WeChat dev mode (MUST be false in production) ===
# When true, /api/app/auth/login accepts any openid without WeChat signature check.
# Only set to true for local development.
WX_DEV_MODE=false
