<wxs src="../../utils/util.wxs" module="util" />

<!-- Event detail page -->
<view class="page" wx:if="{{!loading}}">
  <!-- Event banner -->
  <image class="event-banner" src="{{event.bannerUrl || '/images/default-event.png'}}" mode="aspectFill"></image>

  <!-- Event header -->
  <view class="event-header">
    <view class="event-type-badge {{event.type === 'STAR' ? 'type-star' : 'type-party'}}">
      {{event.type === 'STAR' ? '竞技赛事' : '社交活动'}}
    </view>

    <view class="event-status-badge" style="background-color: {{util.getEventStatusColor(event.status)}}">
      {{util.formatEventStatus(event.status)}}
    </view>
  </view>

  <!-- Event info card -->
  <view class="info-card">
    <view class="event-title">{{event.title}}</view>

    <view class="info-item">
      <text class="info-icon">📅</text>
      <view class="info-content">
        <text class="info-label">比赛时间</text>
        <text class="info-value">{{util.formatDate(event.eventTime, 'YYYY-MM-DD HH:mm')}}</text>
      </view>
    </view>

    <view class="info-item">
      <text class="info-icon">📍</text>
      <view class="info-content">
        <text class="info-label">比赛地点</text>
        <text class="info-value">{{event.location}}</text>
      </view>
    </view>

    <view class="info-item">
      <text class="info-icon">👥</text>
      <view class="info-content">
        <text class="info-label">报名人数</text>
        <text class="info-value">{{event.currentParticipants}}/{{event.maxParticipants}}</text>
      </view>
    </view>

    <view class="info-item">
      <text class="info-icon">💰</text>
      <view class="info-content">
        <text class="info-label">报名费用</text>
        <text class="info-value">{{event.fee > 0 ? '¥' + event.fee : '免费'}}</text>
      </view>
    </view>

    <view class="info-item" wx:if="{{event.minPoints > 0}}">
      <text class="info-icon">⭐</text>
      <view class="info-content">
        <text class="info-label">积分门槛</text>
        <text class="info-value">{{event.minPoints}} 分（{{event.type === 'STAR' ? '战力' : '活力'}}）</text>
      </view>
    </view>

    <view class="info-item">
      <text class="info-icon">⏰</text>
      <view class="info-content">
        <text class="info-label">报名截止</text>
        <text class="info-value">{{util.formatDate(event.registrationDeadline, 'YYYY-MM-DD HH:mm')}}</text>
      </view>
    </view>
  </view>

  <!-- Event description -->
  <view class="section-card" wx:if="{{event.description}}">
    <view class="section-title">📝 活动介绍</view>
    <view class="section-content">{{event.description}}</view>
  </view>

  <!-- Event rules -->
  <view class="section-card" wx:if="{{event.rules}}">
    <view class="section-title">📋 规则说明</view>
    <view class="section-content content-rich">{{event.rules}}</view>
  </view>

  <!-- Event prizes -->
  <view class="section-card" wx:if="{{event.prizes}}">
    <view class="section-title">🏆 奖项说明</view>
    <view class="section-content content-rich">{{event.prizes}}</view>
  </view>

  <!-- Registration status -->
  <view class="status-card" wx:if="{{isRegistered}}">
    <view class="status-header">
      <text class="status-icon">✅</text>
      <text class="status-text">您已报名</text>
    </view>
  </view>

  <!-- Action buttons -->
  <view class="action-bar">
    <!-- Cancel button -->
    <button
      wx:if="{{isRegistered}}"
      class="action-btn cancel-btn"
      bindtap="handleCancel">
      取消报名
    </button>

    <!-- Register button -->
    <button
      wx:elif="{{isRegistrationOpen && !insufficientPoints}}"
      class="action-btn register-btn"
      bindtap="handleRegister">
      立即报名
    </button>

    <!-- Insufficient points button -->
    <button
      wx:elif="{{isRegistrationOpen && insufficientPoints}}"
      class="action-btn disabled-btn"
      disabled>
      积分不足（差 {{pointsGap}} 分）
    </button>

    <!-- Disabled status button -->
    <button
      wx:else
      class="action-btn disabled-btn"
      disabled>
      {{event.status === 'FULL' ? '已满员' : event.status === 'IN_PROGRESS' ? '进行中' : event.status === 'COMPLETED' ? '已结束' : event.status === 'CANCELLED' ? '已取消' : '报名已截止'}}
    </button>

    <!-- View results button (only after event completed) -->
    <button
      wx:if="{{event.status === 'COMPLETED'}}"
      class="action-btn ranking-btn"
      bindtap="handleViewResults">
      查看成绩
    </button>
  </view>
</view>

<!-- Loading state -->
<view wx:if="{{loading}}" class="loading-container">
  <text class="loading-text">加载中...</text>
</view>
