/* Login page styles */
.login-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.login-container {
  width: 100%;
}

.logo-section {
  text-align: center;
  margin-bottom: 120rpx;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
  border-radius: 50%;
  background-color: white;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.app-name {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 16rpx;
}

.app-slogan {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.login-section {
  margin-bottom: 60rpx;
}

.login-btn,
.phone-btn {
  width: 100%;
  height: 96rpx;
  background-color: white;
  border: none;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #4CAF50;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 24rpx;
}

.login-btn:active,
.phone-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.login-btn[disabled],
.phone-btn[disabled] {
  opacity: 0.6;
}

.btn-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.btn-text {
  font-size: 32rpx;
}

.terms-section {
  text-align: center;
}

.terms-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.terms-link {
  font-size: 24rpx;
  color: white;
  text-decoration: underline;
}
