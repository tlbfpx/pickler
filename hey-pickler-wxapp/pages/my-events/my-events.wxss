/* My events page styles */
.placement-badge {
  position: absolute;
  top: 70rpx;
  right: 20rpx;
  background: linear-gradient(135deg, #ff7e5f, #feb47b);
  color: white;
  border-radius: 32rpx;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 126, 95, 0.35);
  z-index: 2;
}

.placement-text {
  color: white;
  font-weight: 500;
}

.tab-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  background-color: white;
  border-bottom: 2rpx solid #f5f5f5;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #4CAF50;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background-color: #4CAF50;
  border-radius: 3rpx;
}

.event-list {
  padding: 20rpx;
}

.event-item {
  position: relative;
  background-color: white;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.event-banner {
  width: 100%;
  height: 320rpx;
  background-color: #f5f5f5;
}

.event-type-badge {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: white;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.type-star {
  background: linear-gradient(135deg, #FF9800, #F57C00);
}

.type-party {
  background: linear-gradient(135deg, #2196F3, #1976D2);
}

.status-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: white;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.event-info {
  padding: 24rpx;
}

.event-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.event-meta {
  margin-bottom: 16rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.meta-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.meta-text {
  font-size: 26rpx;
  color: #666;
}

.registration-time {
  display: flex;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.time-label {
  margin-right: 8rpx;
}

.time-value {
  color: #666;
}

.match-type {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  margin-top: 8rpx;
}

.type-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.type-text {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

.no-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

.empty {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  display: block;
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-hint {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-top: 16rpx;
}
