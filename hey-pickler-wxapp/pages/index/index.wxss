/* Index page styles */
.venue-entry {
  display: flex;
  align-items: center;
  margin: 20rpx 24rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #4CAF50, #45a049);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.25);
}

.venue-entry-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.venue-entry-text {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.venue-entry-arrow {
  font-size: 44rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1;
}

.banner-swiper {
  width: 100%;
  height: 360rpx;
  background-color: #f5f5f5;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.tab-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  background-color: white;
  border-bottom: 2rpx solid #f5f5f5;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 32rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #4CAF50;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background-color: #4CAF50;
  border-radius: 3rpx;
}

.event-list {
  padding: 20rpx;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

.no-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

.empty {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  display: block;
  font-size: 120rpx;
  margin-bottom: 20rpx;
}
