/* Event card styles */
.event-card {
  position: relative;
  background-color: white;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
}

.event-card:active {
  transform: translateY(2rpx);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.08);
}

.event-banner {
  width: 100%;
  height: 360rpx;
  background-color: #f5f5f5;
}

.event-type-badge {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: white;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.type-star {
  background: linear-gradient(135deg, #FF9800, #F57C00);
}

.type-party {
  background: linear-gradient(135deg, #2196F3, #1976D2);
}

.event-status-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: white;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.event-info {
  padding: 24rpx;
}

.event-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.event-meta {
  margin-bottom: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.meta-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.meta-text {
  font-size: 28rpx;
  color: #666;
}

.event-participants {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.participant-count {
  display: flex;
  align-items: center;
}

.count-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.count-text {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.full-badge {
  padding: 6rpx 16rpx;
  background-color: #f44336;
  color: white;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.deadline-badge {
  padding: 6rpx 16rpx;
  background-color: #FFF3E0;
  color: #FF9800;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.register-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #4CAF50, #45a049);
  color: white;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.register-btn:active {
  background: linear-gradient(135deg, #45a049, #3d8b40);
}

.register-btn.disabled {
  background: linear-gradient(135deg, #ccc, #bbb);
  color: #999;
}

.event-format-badge {
  position: absolute;
  top: 100rpx;
  left: 16rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
  z-index: 3;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.15);
}
