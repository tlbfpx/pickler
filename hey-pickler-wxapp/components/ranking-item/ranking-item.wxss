/* Ranking item styles */
.ranking-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: white;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.rank-number {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #666;
  background-color: #f5f5f5;
  border-radius: 50%;
  margin-right: 20rpx;
}

.rank-top {
  font-size: 40rpx;
  background-color: transparent;
}

.rank-high {
  background-color: #FFF3E0;
  color: #FF9800;
}

.rank-normal {
  background-color: #f5f5f5;
  color: #666;
}

.user-info {
  flex: 1;
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background-color: #f5f5f5;
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.user-city {
  font-size: 24rpx;
  color: #999;
}

.ranking-stats {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.user-points {
  font-size: 28rpx;
  font-weight: 600;
  color: #4CAF50;
}

.rank-change {
  font-size: 24rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.change-up {
  color: #4CAF50;
}

.change-down {
  color: #f44336;
}

.change-same {
  color: #999;
}

.change-icon {
  font-size: 20rpx;
}

.change-value {
  font-weight: 500;
}
