/* Tier badge styles（配色/文字色由 inline style 驱动，此处只留布局/尺寸）*/
.tier-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.tier-small {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.tier-medium {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.tier-large {
  font-size: 28rpx;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
}

.tier-icon {
  margin-right: 4rpx;
  font-size: 1em;
  line-height: 1;
}

.tier-text {
  font-weight: 600;
}
