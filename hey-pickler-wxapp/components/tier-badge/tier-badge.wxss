/* Tier badge styles */
.tier-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.tier-bronze {
  background: linear-gradient(135deg, #CD7F32, #A0522D);
  color: white;
}

.tier-silver {
  background: linear-gradient(135deg, #C0C0C0, #9E9E9E);
  color: white;
}

.tier-gold {
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: white;
}

.tier-platinum {
  background: linear-gradient(135deg, #E5E4E2, #B9F2FF);
  color: #333;
}

.tier-diamond {
  background: linear-gradient(135deg, #B9F2FF, #4FC3F7);
  color: #333;
}

.tier-master {
  background: linear-gradient(135deg, #9C27B0, #6A1B9A);
  color: white;
}

.tier-small {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.tier-medium {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.tier-large {
  font-size: 28rpx;
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
}

.tier-text {
  font-weight: 600;
}
