/** WXS util module - for use in WXML templates */

function formatDate(date, format) {
  if (!date) return ''
  var d = getDate(date)
  if (isNaN(d.getTime())) return ''

  var format = format || 'YYYY-MM-DD HH:mm:ss'
  var year = d.getFullYear()
  var month = padZero(d.getMonth() + 1)
  var day = padZero(d.getDate())
  var hours = padZero(d.getHours())
  var minutes = padZero(d.getMinutes())
  var seconds = padZero(d.getSeconds())

  return format
    .replace('YYYY', year)
    .replace('MM', month)
    .replace('DD', day)
    .replace('HH', hours)
    .replace('mm', minutes)
    .replace('ss', seconds)
}

function padZero(n) {
  n = n.toString()
  return n.length < 2 ? '0' + n : n
}

function formatEventStatus(status) {
  var map = {
    DRAFT: '草稿',
    OPEN: '报名中',
    FULL: '已满员',
    IN_PROGRESS: '进行中',
    COMPLETED: '已结束',
    CANCELLED: '已取消'
  }
  return map[status] || status || ''
}

function getEventStatusColor(status) {
  var map = {
    DRAFT: '#999',
    OPEN: '#4CAF50',
    FULL: '#FF9800',
    IN_PROGRESS: '#2196F3',
    COMPLETED: '#666',
    CANCELLED: '#f44336'
  }
  return map[status] || '#999'
}

function formatTier(tier, type) {
  var tierMap = {
    BRONZE: '青铜',
    SILVER: '白银',
    GOLD: '黄金',
    PLATINUM: '铂金',
    DIAMOND: '钻石',
    MASTER: '王者'
  }
  // 积分体系术语：STAR→战力段位 / PARTY→活力段位（与 utils/terms.js 一致）
  var typeSuffix = type === 'PARTY' ? '活力段位' : '战力段位'
  return (tierMap[tier] || '青铜') + typeSuffix
}

function formatMatchType(matchType) {
  var map = {
    SINGLES: '单打',
    DOUBLES: '双打',
    MIXED: '混合双打'
  }
  return map[matchType] || matchType || ''
}

function formatPoints(points) {
  if (points === null || points === undefined) return '0'
  return points.toString()
}

function isRegistrationOpen(event) {
  if (!event) return false
  if (event.status !== 'OPEN') return false
  if (event.currentParticipants >= event.maxParticipants) return false
  var now = getDate()
  var deadline = getDate(event.registrationDeadline)
  return now.getTime() < deadline.getTime()
}

module.exports = {
  formatDate: formatDate,
  formatEventStatus: formatEventStatus,
  getEventStatusColor: getEventStatusColor,
  formatTier: formatTier,
  formatMatchType: formatMatchType,
  formatPoints: formatPoints,
  isRegistrationOpen: isRegistrationOpen
}
