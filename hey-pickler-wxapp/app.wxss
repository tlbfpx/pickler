/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
  font-size: 14px;
  line-height: 1.6;
  color: #333;
}

/* 容器 */
.container {
  padding: 20rpx;
}

.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 主色调 */
.primary-color {
  color: #4CAF50;
}

.bg-primary {
  background-color: #4CAF50;
}

/* 按钮样式 */
.btn-primary {
  background-color: #4CAF50;
  color: white;
  border: none;
  border-radius: 8rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary:active {
  background-color: #45a049;
}

.btn-secondary {
  background-color: #fff;
  color: #4CAF50;
  border: 2rpx solid #4CAF50;
  border-radius: 8rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-disabled {
  background-color: #ccc;
  color: white;
  border: none;
  border-radius: 8rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
}

/* 卡片样式 */
.card {
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 文本样式 */
.text-primary {
  color: #4CAF50;
}

.text-secondary {
  color: #999;
}

.text-danger {
  color: #f44336;
}

.text-success {
  color: #4CAF50;
}

.text-warning {
  color: #ff9800;
}

/* 间距工具类 */
.mt-10 {
  margin-top: 10rpx;
}

.mt-20 {
  margin-top: 20rpx;
}

.mb-10 {
  margin-bottom: 10rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.ml-10 {
  margin-left: 10rpx;
}

.mr-10 {
  margin-right: 10rpx;
}

/* Flex 布局 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
}

.empty-icon {
  font-size: 120rpx;
  color: #ddd;
  margin-bottom: 20rpx;
}

/* 段位徽章 */
.tier-legend {
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: white;
}

.tier-super {
  background: linear-gradient(135deg, #9C27B0, #7B1FA2);
  color: white;
}

.tier-shining {
  background: linear-gradient(135deg, #C0C0C0, #9E9E9E);
  color: white;
}
